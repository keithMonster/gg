<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  gg 全系统状态扫描（4 次/天：00:23 / 06:23 / 12:23 / 18:23，错开 cc-space.tick :17 高密区）。

  职责：
    - 扫所有 com.cc-space.* 和 com.gg.* launchd 任务最近一次运行状态
    - 扫 cc-space morning-brief.md 是否当日产出，提取 [RECURRING] 议题
    - 扫 NW proposals.jsonl L4 blocked / L5 待提议项
    - 一切正常 → 静默退出
    - 发现异常 → 写告警文件到 scheduled/alerts/YYYY-MM-DD-HHmm.md

  频次决策（2026-05-14）：从 24 次/天降到 4 次/天。所有扫描项变化频率都远低于 1h——
    morning-brief 日产 1 次、NW 账本天级别变化、launchd 失败次日 cron 重跑能接上、
    audit P0 静态稀疏。06:23 抓夜跑结果（cgboiler 03:30 / chat 04:30 等），
    其余三点日间补位 + 夜里兜底。省 83% token-equivalent 成本。

  为何 timeout=600：扫描 + 写告警 5 分钟内必须完成，超时即视为卡死。
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.gg.status-scan</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/xuke/githubProject/gg/scheduled/bin/run-task.sh</string>
        <string>com.gg.status-scan</string>
        <string>600</string>
        <string>Read /Users/xuke/githubProject/gg/scheduled/STATUS_SCAN.md，按其中指令逐步执行</string>
    </array>

    <key>StartCalendarInterval</key>
    <array>
        <dict>
            <key>Hour</key>
            <integer>0</integer>
            <key>Minute</key>
            <integer>23</integer>
        </dict>
        <dict>
            <key>Hour</key>
            <integer>6</integer>
            <key>Minute</key>
            <integer>23</integer>
        </dict>
        <dict>
            <key>Hour</key>
            <integer>12</integer>
            <key>Minute</key>
            <integer>23</integer>
        </dict>
        <dict>
            <key>Hour</key>
            <integer>18</integer>
            <key>Minute</key>
            <integer>23</integer>
        </dict>
    </array>

    <key>RunAtLoad</key>
    <false/>
    <key>KeepAlive</key>
    <false/>

    <key>WorkingDirectory</key>
    <string>/Users/xuke/githubProject/gg</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key>
        <string>/Users/xuke</string>
        <key>PATH</key>
        <string>/Users/xuke/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>
</dict>
</plist>
